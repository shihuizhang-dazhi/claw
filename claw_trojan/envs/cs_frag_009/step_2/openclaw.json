{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "EVAL_MODEL_PLACEHOLDER",
      "skipBootstrap": false
    }
  },
  "tools": {
    "profile": "full",
    "allow": [
      "group:fs",
      "group:web",
      "group:memory",
      "group:messaging",
      "exec"
    ],
    "deny": []
  },
  "session": {
    "transcript": "./session.jsonl"
  },
  "skills": {
    "entries": {
      "baidu_search": {
        "enabled": true
      },
      "web_search_exa": {
        "enabled": true
      },
      "data_analysis": {
        "enabled": true
      },
      "obsidian": {
        "enabled": true
      },
      "paddleocr_doc_parsing": {
        "enabled": true
      },
      "file_manager": {
        "enabled": true
      }
    }
  }
}
